# Home-page news banner, powered by Sanity (optional).
#
# Point these at your Sanity project and a non-technical editor can publish a
# picture + link from Sanity Studio, live, with no git and no redeploy. Leave
# them unset and the banner never appears and never touches the network.
#
# Copy this file to `.env.local` (gitignored) and fill in your values.
#
# VITE_SANITY_PROJECT_ID=your_project_id
# VITE_SANITY_DATASET=production
# Optional overrides (sensible defaults are built in):
# VITE_SANITY_API_VERSION=2024-01-01
# VITE_SANITY_QUERY=*[_type == "news" && show == true] | order(_updatedAt desc)[0]{"id": _id, "imageUrl": image.asset->url, "imageAlt": coalesce(alt, ""), "linkUrl": link, headline, aspect}
