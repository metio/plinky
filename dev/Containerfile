# Playwright's own image ships the browsers and their system libraries, and sets
# PLAYWRIGHT_BROWSERS_PATH, so the browser test project runs locally without a
# per-run `playwright install --with-deps`. Keep the tag in step with the
# `playwright` dependency in package.json so the baked browsers match.
# renovate: datasource=docker depName=mcr.microsoft.com/playwright
FROM mcr.microsoft.com/playwright:v1.61.1-noble@sha256:5b8f294aff9041b7191c34a4bab3ac270157a28774d4b0660e9743297b697e48

# A mounted repo is owned by the host user, so git refuses it as "dubious
# ownership". Trust any working directory, otherwise reuse falls back to walking
# the tree (node_modules and all) instead of honoring .gitignore.
RUN git config --system --add safe.directory '*'

# CI-gate tooling that is not a project dependency, so a local run reproduces the
# verify workflow. The project's own tools (biome, knip, vite, vitest, tsc) come
# from `npm install` and run via npx, pinned by package.json.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl jq python3-pip yamllint shellcheck \
    && rm -rf /var/lib/apt/lists/*

# reuse: the licensing linter the CI reuse job runs (fsfe/reuse-action). The
# Debian package predates REUSE.toml, so install the current release from PyPI.
# renovate: datasource=pypi depName=reuse
ARG REUSE_VERSION=6.2.0
RUN pip install --break-system-packages --no-cache-dir "reuse==${REUSE_VERSION}"

# markdownlint-cli2 mirrors the DavidAnson/markdownlint-cli2-action in verify.yml,
# so `markdownlint-cli2 '**/*.md'` reproduces the CI markdown gate locally against
# .markdownlint.yaml.
# renovate: datasource=npm depName=markdownlint-cli2
ARG MARKDOWNLINT_CLI2_VERSION=0.22.1
RUN npm install -g markdownlint-cli2@${MARKDOWNLINT_CLI2_VERSION}

# typos: the spell-checker the CI `typos` job runs. A Rust binary fetched as the
# prebuilt release, kept in step with the crate-ci/typos action so a local run
# catches exactly what CI does.
# renovate: datasource=github-releases depName=crate-ci/typos
ARG TYPOS_VERSION=1.47.2
RUN ARCH="$(uname -m)" \
    && case "$ARCH" in x86_64) T=x86_64 ;; aarch64) T=aarch64 ;; *) T="$ARCH" ;; esac \
    && curl -fsSL "https://github.com/crate-ci/typos/releases/download/v${TYPOS_VERSION}/typos-v${TYPOS_VERSION}-${T}-unknown-linux-musl.tar.gz" \
       | tar -xz -C /usr/local/bin ./typos

# actionlint: the GitHub Actions linter the CI `github-actions` job runs
# (reviewdog/action-actionlint). It shells out to shellcheck for `run:` blocks,
# installed above. Prebuilt release binary.
# renovate: datasource=github-releases depName=rhysd/actionlint
ARG ACTIONLINT_VERSION=1.7.12
RUN ARCH="$(uname -m)" \
    && case "$ARCH" in x86_64) A=amd64 ;; aarch64) A=arm64 ;; *) A="$ARCH" ;; esac \
    && curl -fsSL "https://github.com/rhysd/actionlint/releases/download/v${ACTIONLINT_VERSION}/actionlint_${ACTIONLINT_VERSION}_linux_${A}.tar.gz" \
       | tar -xz -C /usr/local/bin actionlint
