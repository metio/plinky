# Sanity Studio config. Copy to .env and fill in your project's values.
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
# The hosted Studio will live at <hostname>.sanity.studio (must be globally unique):
SANITY_STUDIO_HOSTNAME=plinky-cms
