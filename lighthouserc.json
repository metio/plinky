{
  "ci": {
    "collect": {
      "staticDistDir": "./build/client",
      "url": [
        "http://localhost/en/",
        "http://localhost/en/compose/",
        "http://localhost/en/library/",
        "http://localhost/en/play/47xd2XDpYFCy/",
        "http://localhost/en/you/",
        "http://localhost/en/settings/"
      ],
      "numberOfRuns": 3,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertMatrix": [
        {
          "comment": "The score viewer lazy-loads OpenSheetMusicDisplay, so /play pages ship a much larger script payload than the rest of the app. Budget them apart so the OSMD bulk can't hide an app-code regression on the lighter pages, and the lighter pages' tight cap still trips on a real one. The cap was raised for the full 26-locale translation (every visitor's bundle carries all languages, ~+70 KB here); per-locale JS builds are the planned follow-up that lets it ratchet back down.",
          "matchingUrlPattern": ".*/play/.*",
          "assertions": {
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }],
            "categories:performance": ["warn", { "minScore": 0.9 }],
            "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
            "resource-summary:script:size": ["error", { "maxNumericValue": 686080 }],
            "service-worker": "off",
            "uses-responsive-images": "off",
            "redirects-http": "off",
            "is-on-https": "off",
            "uses-http2": "off",
            "canonical": "off"
          }
        },
        {
          "comment": "Every page that does not load the OSMD vendor chunk. The script cap is a tight ratchet on the shared/app code shipped to a normal page. Raised for the full 26-locale translation (all languages ride in the shared bundle, ~+17 KB here); per-locale JS builds are the planned follow-up that lets it ratchet back down.",
          "matchingUrlPattern": "^(?!.*/play/).*$",
          "assertions": {
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }],
            "categories:performance": ["warn", { "minScore": 0.9 }],
            "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
            "resource-summary:script:size": ["error", { "maxNumericValue": 256000 }],
            "service-worker": "off",
            "uses-responsive-images": "off",
            "redirects-http": "off",
            "is-on-https": "off",
            "uses-http2": "off",
            "canonical": "off"
          }
        }
      ]
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
